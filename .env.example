# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Optional: Model to use (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Maximum agent turns before timeout (default: 12)
MAX_AGENT_TURNS=12

# Optional: Enable debug logging (default: false)
DEBUG=false
